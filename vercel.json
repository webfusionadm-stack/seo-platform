{
  "framework": null,
  "buildCommand": "npm ci --include=dev && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/keyword-schedules", "schedule": "0 0 * * *" },
    { "path": "/api/cron/publications", "schedule": "0 0 * * *" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "apps/backend/prisma/schema.prisma"
    }
  }
}
